<!DOCTYPE html>
<html lang="{{ app.request.locale }}" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ 'demo.title'|trans({}, 'messages') }}{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body.tiptap-demo-dark { background-color: #0f172a; color: #e2e8f0; }
        body.tiptap-demo-dark .lead, body.tiptap-demo-dark .text-muted { color: #94a3b8 !important; }
    </style>
</head>
<body>
    {% set _locale = app.request.locale %}
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home', { _locale: _locale }) }}">{{ 'demo.title'|trans({}, 'messages') }}</a>
            <div class="navbar-nav">
                <a class="nav-link {{ app.request.attributes.get('_route') == 'app_home' ? 'active' : '' }}" href="{{ path('app_home', { _locale: _locale }) }}">{{ 'demo.menu_home'|trans({}, 'messages') }}</a>
                <a class="nav-link {{ app.request.attributes.get('_route') == 'app_demo' ? 'active' : '' }}" href="{{ path('app_demo', { _locale: _locale }) }}">{{ 'demo.menu_demo'|trans({}, 'messages') }}</a>
                <a class="nav-link {{ app.request.attributes.get('_route') == 'app_demo_configs' ? 'active' : '' }}" href="{{ path('app_demo_configs', { _locale: _locale }) }}">{{ 'demo.menu_configs'|trans({}, 'messages') }}</a>
                <a class="nav-link {{ app.request.attributes.get('_route') == 'app_showcase' ? 'active' : '' }}" href="{{ path('app_showcase', { _locale: _locale }) }}">{{ 'demo.menu_showcase'|trans({}, 'messages') }}</a>
                <a class="nav-link {{ app.request.attributes.get('_route') in ['app_examples_index', 'app_examples_show'] ? 'active' : '' }}" href="{{ path('app_examples_index', { _locale: _locale }) }}">{{ 'demo.menu_examples'|trans({}, 'messages') }}</a>
            </div>
            <ul class="navbar-nav ms-auto align-items-lg-center gap-2">
                <li class="nav-item">
                    <button type="button" class="btn btn-sm btn-outline-light" id="tiptap-demo-theme-toggle" title="{{ 'demo.theme_toggle_title'|trans({}, 'messages') }}">{{ 'demo.theme_dark'|trans({}, 'messages') }}</button>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">{{ _locale == 'es' ? 'Español' : 'English' }}</a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="{{ path('app_home', { _locale: 'en' }) }}">English</a></li>
                        <li><a class="dropdown-item" href="{{ path('app_home', { _locale: 'es' }) }}">Español</a></li>
                    </ul>
                </li>
            </ul>
        </div>
    </nav>
    {% block body %}{% endblock %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
(function () {
    var KEY = 'tiptapDemoDark';
    function apply(dark) {
        document.body.classList.toggle('tiptap-demo-dark', dark);
        document.body.classList.toggle('tiptap-demo-light', !dark);
        document.documentElement.setAttribute('data-bs-theme', dark ? 'dark' : 'light');
        var nav = document.querySelector('.navbar.navbar-dark.bg-dark');
        if (nav) {
            nav.classList.toggle('navbar-dark', dark);
            nav.classList.toggle('bg-dark', dark);
            nav.classList.toggle('navbar-light', !dark);
            nav.classList.toggle('bg-light', !dark);
        }
        var btn = document.getElementById('tiptap-demo-theme-toggle');
        if (btn) {
            btn.textContent = dark
                ? '{{ 'demo.theme_light'|trans({}, 'messages')|e('js') }}'
                : '{{ 'demo.theme_dark'|trans({}, 'messages')|e('js') }}';
            btn.classList.toggle('btn-outline-dark', dark);
            btn.classList.toggle('btn-outline-light', !dark);
        }
    }
    var stored = localStorage.getItem(KEY);
    var dark = stored === null ? false : stored === '1';
    apply(dark);
    document.getElementById('tiptap-demo-theme-toggle')?.addEventListener('click', function () {
        dark = !document.body.classList.contains('tiptap-demo-dark');
        localStorage.setItem(KEY, dark ? '1' : '0');
        apply(dark);
    });
})();
    </script>
</body>
</html>
