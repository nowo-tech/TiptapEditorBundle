{% extends 'base.html.twig' %}

{% block title %}{{ 'examples.page_title'|trans({}, 'messages') }} – {{ 'demo.title'|trans({}, 'messages') }}{% endblock %}

{% block body %}
<div class="container py-4">
    <h1 class="h2">{{ 'examples.page_title'|trans({}, 'messages') }}</h1>
    <p class="lead">{{ 'examples.page_lead'|trans({}, 'messages') }}</p>
    <p>
        <a href="{{ 'examples.docs_url'|trans({}, 'messages') }}" rel="noopener noreferrer" target="_blank">{{ 'examples.doc_hub_link'|trans({}, 'messages') }}</a>
    </p>

    {% for section in sections %}
        <h2 class="h4 mt-4">{{ section.title|trans({}, 'messages') }}</h2>
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
            {% for slug in section.slugs %}
                {% set title_key = 'examples.card.' ~ slug ~ '.title' %}
                {% set desc_key = 'examples.card.' ~ slug ~ '.desc' %}
                <div class="col">
                    <div class="card h-100 shadow-sm position-relative">
                        <div class="card-body d-flex flex-column">
                            <div class="mb-2">
                                {% if slug in liveExampleSlugs %}
                                    <span class="badge text-bg-success">{{ 'examples.badge_live'|trans({}, 'messages') }}</span>
                                {% else %}
                                    <span class="badge text-bg-secondary">{{ 'examples.badge_stub'|trans({}, 'messages') }}</span>
                                {% endif %}
                            </div>
                            <h3 class="h6 card-title">{{ title_key|trans({}, 'messages') }}</h3>
                            <p class="card-text small text-body-secondary flex-grow-1">{{ desc_key|trans({}, 'messages') }}</p>
                            <a class="btn btn-sm btn-outline-primary stretched-link" href="{{ path('app_examples_show', { _locale: app.request.locale, slug: slug }) }}">{{ 'examples.open'|trans({}, 'messages') }}</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endfor %}
</div>
{% endblock %}
