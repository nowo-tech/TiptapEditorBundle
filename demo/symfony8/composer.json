{
    "name": "nowo-tech/tiptap-editor-demo-symfony8",
    "description": "Demo for Tiptap Editor Bundle - Symfony 8",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "nowo-tech/tiptap-editor-bundle": "@dev",
        "symfony/asset": "^8.0",
        "symfony/console": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/flex": "^2.0",
        "symfony/form": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/runtime": "^8.0",
        "symfony/translation": "8.1.*",
        "symfony/twig-bundle": "^8.0",
        "symfony/yaml": "^8.0"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": ["@auto-scripts"],
        "post-update-cmd": ["@auto-scripts"],
        "test": "@php -r \"fwrite(STDOUT, 'demo-smoke'.PHP_EOL);\"",
        "test-coverage": "@test"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.1.*"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "/var/tiptap-editor-bundle"
        }
    ],
    "require-dev": {
        "nowo-tech/twig-inspector-bundle": "*",
        "symfony/debug-bundle": "^8.0",
        "symfony/var-dumper": "^8.0",
        "symfony/web-profiler-bundle": "^8.0"
    }
}
